<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Added</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body class="min-h-screen bg-slate-50">
    <div class="mx-auto flex min-h-screen max-w-3xl items-center justify-center px-6 py-16">
        <div class="w-full rounded-3xl border border-slate-200 bg-white p-10 text-center shadow-xl">
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-green-600">Success</p>
            <h1 class="mb-4 text-3xl font-bold text-slate-900">Your home has been added</h1>
            <p class="mb-8 text-slate-600">Your listing is ready to be reviewed and shared with guests.</p>
            <a href="/" class="rounded-full bg-blue-600 px-6 py-3 font-semibold text-white transition hover:bg-blue-700">Go to Add Home</a>
        </div>
        <section class="mt-10 w-full text-left ml-10">
            <div class="mb-6 ">
                <h2 class="text-2xl font-semibold text-slate-900">Registered Homes</h2>
                <p class="mt-2 text-sm text-slate-500">Here are the homes you’ve added so far.</p>
            </div>

            <% if (registerHome && registerHome.length > 0) { %>
                <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                    <% registerHome.forEach(home => { %>
                        <article class="overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl p-7 ">
                            <div class="relative h-44 bg-gradient-to-br from-slate-200 via-slate-100 to-slate-300">
                                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.7),_transparent_55%)]"></div>
                                <div class="absolute bottom-4 left-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-[0.25em] text-slate-700 shadow-sm">
                                    Featured
                                </div>
                            </div>

                            <div class="p-5">
                                <div class="mb-3 flex items-start justify-between gap-3">
                                    <div>
                                        <h3 class="text-lg font-semibold text-slate-900"><%= home.houseName %></h3>
                                        <p class="mt-1 text-sm text-slate-500">Entire home • Superhost</p>
                                    </div>
                                    <div class="flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-sm font-medium text-amber-600">
                                        <span>★</span>
                                        <span>4.9</span>
                                    </div>
                                </div>

                                <div class="space-y-2 text-sm text-slate-600">
                                    <p><span class="font-semibold text-slate-700">Address:</span> <%= home.houseAddress %></p>
                                    <p><span class="font-semibold text-slate-700">Price:</span> $<%= home.housePrice %> / night</p>
                                </div>

                                <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
                                    <span class="rounded-full bg-blue-50 px-3 py-1 text-sm font-medium text-blue-700">Listed</span>
                                    <button class="text-sm font-semibold text-slate-900 transition hover:text-blue-600">View details</button>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-500">
                    No homes registered yet.
                </div>
            <% } %>
        </section>
    </div>
</body>
</html>