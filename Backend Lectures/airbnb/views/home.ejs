<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>airbnb Home</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-white to-slate-200 text-slate-800">
    <header class="bg-white shadow-sm">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
            <h1 class="text-2xl font-bold text-slate-900">Airbnb</h1>
            <a href="/" class="rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">Back to Home</a>
        </div>
    </header>

    <main class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-12 lg:flex-row lg:items-center">
        <section class="flex-1">
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-blue-600">Welcome</p>
            <h2 class="mb-4 text-4xl font-bold leading-tight sm:text-5xl">Find your next perfect stay</h2>
            <p class="mb-8 max-w-xl text-lg text-slate-600">Discover cozy homes, scenic retreats, and modern stays in the most beautiful places.</p>
        </section>

        <section class="w-full max-w-xl rounded-2xl border border-slate-200 bg-white p-8 shadow-xl">
            <h3 class="mb-4 text-2xl font-semibold text-slate-900">List a home</h3>
            <form action="/add-home" method="POST" class="space-y-4">
                <input type="text" name="houseName" placeholder="Enter house name" required class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none ring-0 focus:border-blue-500">
                <input type="text" name="houseAddress" placeholder="Enter location" required class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none ring-0 focus:border-blue-500">
                <input type="number" name="housePrice" placeholder="Enter price per night" required class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none ring-0 focus:border-blue-500">
                <button class="w-full rounded-xl bg-slate-900 px-4 py-3 font-semibold text-white transition hover:bg-slate-700">Submit</button>
            </form>
        </section>
  
    </main>
</body>
</html>